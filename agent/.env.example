# OpenClaw Agent — Environment Variables
# Copy to .env and fill in values before running

# OpenAI API key (used by OpenClaw for gpt-5.5 model)
OPENAI_API_KEY=

# ElevenLabs credentials (for reference — used by ElevenLabs dashboard config)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Backend API URL (Fastify backend, default: localhost:3005)
BACKEND_URL=http://localhost:3005

# Webhook auth token — must match gateway.auth.token in openclaw.json
# Get current token: openclaw config get gateway.auth.token
WEBHOOK_TOKEN=
