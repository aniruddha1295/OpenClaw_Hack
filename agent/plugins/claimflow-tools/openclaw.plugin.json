{
  "id": "claimflow-tools",
  "name": "ClaimFlow Backend Tools",
  "contracts": {
    "tools": [
      "lookup_claim",
      "check_policy",
      "check_documents",
      "file_claim",
      "escalate_to_human",
      "schedule_callback"
    ]
  },
  "activation": { "onStartup": true },
  "configSchema": {
    "type": "object",
    "properties": {
      "backendUrl": {
        "type": "string",
        "description": "Base URL for the ClaimFlow backend API",
        "default": "http://localhost:3005"
      }
    }
  }
}
