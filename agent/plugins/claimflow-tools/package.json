{
  "name": "@claimflow/openclaw-tools",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": { "pluginApi": ">=2026.3.24-beta.2" }
  },
  "scripts": {
    "build": "tsup index.ts --format esm --out-dir dist --external openclaw --external @sinclair/typebox --no-splitting"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.0.0"
  }
}
