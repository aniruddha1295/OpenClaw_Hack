{
  agents: {
    defaults: {
      model: { primary: "openai/gpt-4o" }
    }
  },
  providers: {
    openai: { apiKey: "${OPENAI_API_KEY}" }
  },
  hooks: {
    endpoints: [{
      path: "/webhook/elevenlabs",
      token: "${WEBHOOK_TOKEN}",
      agent: "main"
    }]
  },
  skills: {
    load: {
      extraDirs: ["./skills"],
      watch: true
    }
  },
  plugins: {
    enabled: true,
    entries: {
      "claimflow-tools": { enabled: true }
    }
  },
  gateway: {
    port: 18789,
    bind: "loopback",
    auth: "token"
  }
}
